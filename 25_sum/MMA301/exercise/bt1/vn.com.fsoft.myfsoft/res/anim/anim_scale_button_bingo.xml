<?xml version="1.0" encoding="utf-8"?>
<set
  xmlns:android="http://schemas.android.com/apk/res/android">
    <set android:startOffset="0" android:repeatMode="reverse">
        <scale android:duration="100" android:pivotX="50.0%" android:pivotY="50.0%" android:fromXScale="1.0" android:toXScale="1.1" android:fromYScale="1.0" android:toYScale="1.1" />
    </set>
    <set android:startOffset="200">
        <scale android:duration="200" android:pivotX="50.0%" android:pivotY="50.0%" android:fromXScale="1.1" android:toXScale="0.9" android:fromYScale="1.1" android:toYScale="0.9" />
    </set>
    <set android:startOffset="400">
        <scale android:duration="300" android:pivotX="50.0%" android:pivotY="50.0%" android:fromXScale="0.95" android:toXScale="1.0" android:fromYScale="0.95" android:toYScale="1.0" />
    </set>
    <set android:startOffset="700">
        <alpha android:duration="1500" android:fromAlpha="1.0" android:toAlpha="1.0" />
    </set>
</set>
