<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <size android:height="12.0dip" />
            <corners android:radius="25.0dip" />
            <solid android:color="@color/color_EBEBEB" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%" android:useIntrinsicSizeAsMinimum="true">
            <shape android:shape="rectangle">
                <corners android:radius="25.0dip" />
                <size android:height="12.0dip" android:width="12.0dip" />
                <solid android:color="@color/color_185ECE" />
            </shape>
        </scale>
    </item>
</layer-list>
