<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:useLevel="false" android:thickness="@dimen/_16dp">
            <solid android:color="@color/salehub_performance_progressbar_bg_color" />
        </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270.0" android:toDegrees="270.0">
            <shape android:shape="ring" android:useLevel="true" android:thickness="@dimen/_16dp">
                <solid android:color="@color/salehub_performance_progressbar_indicator_color" />
            </shape>
        </rotate>
    </item>
</layer-list>
