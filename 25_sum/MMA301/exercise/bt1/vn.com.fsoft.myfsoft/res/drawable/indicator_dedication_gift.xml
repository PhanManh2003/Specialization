<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="ring" android:useLevel="false" android:innerRadius="@dimen/_0dp" android:thickness="@dimen/_3dp">
                    <solid android:color="@color/colorWhite" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="ring" android:useLevel="false" android:innerRadius="@dimen/_0dp" android:thickness="@dimen/_3dp">
                    <solid android:color="#80ffffff" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
