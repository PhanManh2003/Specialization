<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorWhite" />
            <corners android:radius="@dimen/_8dp" />
        </shape>
    </item>
    <item android:left="@dimen/_2dp" android:top="@dimen/_2dp" android:right="@dimen/_2dp" android:bottom="@dimen/_2dp">
        <shape android:shape="rectangle">
            <gradient android:startColor="#ffdefff9" android:endColor="#ffddebff" android:angle="0.0" />
            <corners android:radius="@dimen/_8dp" />
        </shape>
    </item>
</layer-list>
