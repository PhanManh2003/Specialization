<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/color_1A2970" />
            <corners android:radius="@dimen/_7dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <gradient android:startColor="@color/color_FEDB79" android:endColor="@color/color_FF9E03" android:angle="180.0" />
                <corners android:radius="@dimen/_7dp" />
            </shape>
        </clip>
    </item>
</layer-list>
