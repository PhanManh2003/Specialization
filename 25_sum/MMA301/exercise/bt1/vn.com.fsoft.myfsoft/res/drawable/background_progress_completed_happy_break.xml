<?xml version="1.0" encoding="utf-8"?>
<layer-list
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="@dimen/_8dp" />
            <solid android:color="@color/colorWhite" />
            <padding android:left="@dimen/_1dp" android:top="@dimen/_1dp" android:right="@dimen/_1dp" android:bottom="@dimen/_1dp" />
        </shape>
    </item>
    <item android:id="@android:id/progress" android:left="1.0dip" android:top="1.0dip" android:right="1.0dip" android:bottom="1.0dip">
        <scale android:scaleWidth="100%">
            <shape>
                <corners android:radius="@dimen/_8dp" />
                <gradient android:startColor="#ffff8f3b" android:endColor="#fff9d850" android:angle="90.0" />
            </shape>
        </scale>
    </item>
</layer-list>
